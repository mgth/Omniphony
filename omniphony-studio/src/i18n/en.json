  "distance.curve": "Curve",
  "distance.infoTitle": "Distance Diffuse",
  "distance.infoBody": "Distance Diffuse blends each object with a mirrored version of itself (opposite horizontal direction) depending on distance. Close objects become wider/more diffuse, while far objects stay mostly direct.<br><br><strong>Threshold</strong>: distance where the blend reaches 100% direct.<br><strong>Curve</strong>: transition shape (faster or slower near-field blend).",
  "spread.distanceInfoTitle": "Spread from Distance",
  "spread.distanceInfoBody": "Spread from Distance replaces object_size spread with a distance-driven spread value.<br><br>Formula: <strong>spread = (1 - distance/range)^curve</strong>, clamped to [0, 1], then mapped to the global spread min/max range.<br><br><strong>Range</strong>: distance where spread reaches 0.<br><strong>Curve</strong>: transition shape (higher = less spread near listener, more collapse farther away).",
  "trail.title": "Trails",
  "trail.infoTitle": "Trails",
  "trail.infoButton": "Trails info",
  "trail.infoBody": "Trails show each object's recent movement history in the 3D view.<br><br><strong>Mode</strong>: choose between a classic line or a diffuse particle trail.<br><strong>Duration</strong>: how long trail points stay visible before fading out.",
  "trail.show": "Show",
  "trail.mode": "Mode",
  "trail.duration": "Duration",
  "trail.mode.diffuse": "Diffuse",
