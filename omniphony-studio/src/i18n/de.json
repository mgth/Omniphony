  "distance.curve": "Kurve",
  "distance.infoTitle": "Distance Diffuse",
  "distance.infoBody": "Distance Diffuse mischt jedes Objekt abhängig von der Entfernung mit einer gespiegelten Version von sich selbst (entgegengesetzte horizontale Richtung). Nahe Objekte werden breiter / diffuser, während entfernte Objekte überwiegend direkt bleiben.<br><br><strong>Schwellwert</strong>: Entfernung, bei der die Mischung 100 % direkt erreicht.<br><strong>Kurve</strong>: Form des Übergangs (schneller oder langsamer im Nahfeld).",
  "spread.distanceInfoTitle": "Spread aus Entfernung",
  "spread.distanceInfoBody": "Spread from Distance ersetzt den `object_size`-Spread durch einen entfernungsabhängigen Spread-Wert.<br><br>Formel: <strong>spread = (1 - distance/range)^curve</strong>, auf [0, 1] begrenzt und anschließend auf den globalen Spread-Min/Max-Bereich abgebildet.<br><br><strong>Bereich</strong>: Entfernung, bei der der Spread 0 erreicht.<br><strong>Kurve</strong>: Übergangsform (höher = weniger Spread nahe am Hörer, stärkerer Kollaps in größerer Entfernung).",
  "trail.title": "Spuren",
  "trail.infoTitle": "Spuren",
  "trail.infoButton": "Spuren-Info",
  "trail.infoBody": "Spuren zeigen den jüngsten Bewegungsverlauf jedes Objekts in der 3D-Ansicht.<br><br><strong>Modus</strong>: Wahl zwischen einer klassischen Linie oder einer diffusen Partikelspur.<br><strong>Dauer</strong>: Wie lange Spurpunkte sichtbar bleiben, bevor sie ausblenden.",
  "trail.show": "Anzeigen",
  "trail.mode": "Modus",
  "trail.duration": "Dauer",
  "trail.mode.diffuse": "Diffus",
  "trail.mode.line": "Linie",
